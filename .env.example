# 跨境ERP多Agent自动化 — 环境变量模板
# 复制为 .env 后填入你的 API Key
#
# ⚠️ .env 已在 .gitignore 中，不会提交到 GitHub

# === DeepSeek 文字模型 ===
# 合规审查 / 标题优化 / 法规查询 均走这个
# 获取: https://platform.deepseek.com/api_keys
# 注册后创建 API Key，充值后使用。文字模型很便宜。
LLM_API_KEY=sk-你的DeepSeekKey          # ← 替换为你自己的 Key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TEXT_MODEL=deepseek-chat             # 稳定，不报错
LLM_LIGHT_MODEL=deepseek-v4-flash       # 轻量版，类目识别用

# === 阿里百炼 视觉模型 ===
# 图片合规分析（OCR置信度不足时兜底）
# 获取: https://bailian.console.aliyun.com → API Key 管理
# 需要开通百炼服务 + 确保 qwen3.6-plus 模型有调用权限
VISION_API_KEY=sk-你的阿里百炼Key       # ← 替换为你自己的 Key
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_IMAGE_MODEL=qwen3.6-plus            # 强于 qwen-vl-plus
