# 跨境ERP多Agent自动化 — 环境变量模板
# 复制为 .env 后填入你的 API Key
#
# cp .env.example .env
#
# ⚠️ .env 已在 .gitignore 中，不会提交到 GitHub

# === DeepSeek 文字模型 ===
# 合规审查 / 标题优化 / 法规查询 均走这个
# 获取: https://platform.deepseek.com/api_keys
LLM_API_KEY=sk-你的DeepSeekKey
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TEXT_MODEL=deepseek-v4-flash
LLM_LIGHT_MODEL=deepseek-v4-flash

# === 阿里百炼 视觉模型 ===
# 图片OCR置信度不足时的兜底分析
# 获取: https://bailian.console.aliyun.com → API Key 管理
VISION_API_KEY=sk-你的阿里百炼Key
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_IMAGE_MODEL=qwen3-vl-plus
